{
  "manifest_version": 3,
  "name": "MarkPull",
  "version": "1.0.0",
  "description": "Extract webpage content into clean, linted Markdown.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "action": {
    "default_title": "Open MarkPull"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ]
}
