{
  "manifest_version": 3,
  "name": "MarkPull",
  "version": "1.0.0",
  "description": "Extract webpage content into clean, linted Markdown.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost/*"
  ],
  "oauth2": {
    "client_id": "497709704899-4mh2fdrh22t82dm5q116g72mmql52c01.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/generative-language.retriever" 
    ]
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "Open MarkPull"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["*"],
      "matches": ["<all_urls>"]
    }
  ]
}
